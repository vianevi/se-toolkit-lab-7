# Bot configuration - copy this file to .env.bot.secret and fill in real values
# NEVER commit .env.bot.secret to git - it contains secrets

# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your-bot-token-from-botfather

# LMS Backend API
LMS_API_BASE_URL=http://localhost:42002
LMS_API_KEY=your-lms-api-key

# LLM API (for Task 3 - intent recognition)
LLM_API_BASE_URL=http://localhost:42005/v1
LLM_API_KEY=your-llm-api-key
LLM_API_MODEL=coder-model
